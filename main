const ALL_USERS = [...JUDGES, ...PARTICIPANTS];

// ════════════════════════════════════════
// STATE
// ════════════════════════════════════════
let db = null;
let demoMode = false;
let currentUser = null;
let myPicks = [null, null, null]; // [1st, 2nd, 3rd] → idea IDs
let allVotes = {}; // { userId: [id1, id2, id3] }
let filter = 'all';
let lastRanking = []; // for animation diffing

// ════════════════════════════════════════
// INIT
// ════════════════════════════════════════
function init() {
  try {
    firebase.initializeApp(FIREBASE_CONFIG);
    db = firebase.database();
    db.ref('.info/connected').on('value', snap => {
      const dot = document.getElementById('statusDot');
      if (snap.val()) {
        dot.classList.remove('offline');
        dot.textContent = 'LIVE';
      } else {
        dot.classList.add('offline');
        dot.textContent = 'OFFLINE';
      }
    });
    db.ref('votes').on('value', snap => {
      allVotes = snap.val() || {};
      renderLeaderboard();
      // If current user has saved votes, restore them
      if (currentUser && allVotes[currentUser.id] && !myPicks.some(p => p)) {
        myPicks = allVotes[currentUser.id].slice(0, 3);
        renderSlots();
        renderIdeaList();
      }
    });
  } catch(e) {
    console.error('Firebase failed, demo mode:', e);
    demoMode = true;
    document.getElementById('statusDot').classList.add('offline');
    document.getElementById('statusDot').textContent = 'DEMO';
    const local = localStorage.getItem('hack_votes');
    allVotes = local ? JSON.parse(local) : {};
  }

  // Restore session
  const saved = localStorage.getItem('hack_user');
  if (saved) {
    currentUser = ALL_USERS.find(u => u.id === saved);
    if (currentUser) { showApp(); return; }
  }
  showLogin();
}

// ════════════════════════════════════════
// LOGIN
// ════════════════════════════════════════
function showLogin() {
  document.getElementById('loginScreen').classList.remove('hidden');
  document.getElementById('mainApp').classList.add('hidden');
  document.getElementById('judgeGrid').innerHTML = JUDGES.map(u => `
    <div class="user-card judge" onclick="selectUser('${u.id}')">
      <div class="name">${u.name}</div>
      <div class="role">⚖️ Judge</div>
    </div>
  `).join('');
  document.getElementById('peerGrid').innerHTML = PARTICIPANTS.map(u => `
    <div class="user-card" onclick="selectUser('${u.id}')">
      <div class="name">${u.name}</div>
      <div class="role">🎤 Voter</div>
    </div>
  `).join('');
}

function selectUser(id) {
  currentUser = ALL_USERS.find(u => u.id === id);
  localStorage.setItem('hack_user', id);
  // Restore their picks if they already voted
  if (allVotes[id]) myPicks = allVotes[id].slice(0, 3);
  showApp();
}

function logout() {
  if (!confirm('Switch user? Your current picks will stay saved.')) return;
  currentUser = null;
  myPicks = [null, null, null];
  localStorage.removeItem('hack_user');
  showLogin();
}

// ════════════════════════════════════════
// APP
// ════════════════════════════════════════
function showApp() {
  document.getElementById('loginScreen').classList.add('hidden');
  document.getElementById('mainApp').classList.remove('hidden');
  const roleEmoji = currentUser.role === 'judge' ? '⚖️' : '🎤';
  document.getElementById('currentUser').innerHTML = `${roleEmoji} ${currentUser.name.split(' ')[0]}`;
  renderSlots();
  renderIdeaList();
  renderLeaderboard();
}

function showPanel(name, evt) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  evt.target.classList.add('active');
  if (name === 'leaderboard') renderLeaderboard();
}

function setFilter(f, evt) {
  filter = f;
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  evt.target.classList.add('active');
  renderIdeaList();
}

// ════════════════════════════════════════
// VOTING
// ════════════════════════════════════════
function pickIdea(ideaId) {
  // Already picked? Remove it
  const existingIdx = myPicks.indexOf(ideaId);
  if (existingIdx !== -1) {
    myPicks[existingIdx] = null;
    renderSlots();
    renderIdeaList();
    return;
  }
  // Find next empty slot
  const emptyIdx = myPicks.indexOf(null);
  if (emptyIdx === -1) {
    showToast('All 3 slots filled. Tap one to clear.', true);
    return;
  }
  myPicks[emptyIdx] = ideaId;
  renderSlots();
  renderIdeaList();
  // Mini celebration
  vibrate(20);
}

function removePick(slotIdx) {
  if (myPicks[slotIdx] === null) return;
  myPicks[slotIdx] = null;
  renderSlots();
  renderIdeaList();
}

function renderSlots() {
  for (let i = 0; i < 3; i++) {
    const slot = document.getElementById('slot-' + i);
    const nameEl = document.getElementById('slot-name-' + i);
    if (myPicks[i]) {
      const idea = IDEAS.find(x => x.id === myPicks[i]);
      slot.classList.add('filled');
      nameEl.textContent = idea ? idea.name : '';
    } else {
      slot.classList.remove('filled');
      nameEl.textContent = '';
    }
  }
  const filled = myPicks.filter(p => p).length;
  const btn = document.getElementById('submitBtn');
  btn.disabled = filled < 3;
  btn.textContent = filled === 3 ? 'SUBMIT VOTES 🚀' : `PICK ${3-filled} MORE...`;
}

function renderIdeaList() {
  const search = (document.getElementById('searchBox')?.value || '').toLowerCase();
  const list = document.getElementById('ideaList');
  const filtered = IDEAS.filter(i => {
    if (filter !== 'all' && i.track !== filter) return false;
    if (search && !i.name.toLowerCase().includes(search) && !i.author.toLowerCase().includes(search)) return false;
    return true;
  });

  list.innerHTML = filtered.map(idea => {
    const pickIdx = myPicks.indexOf(idea.id);
    const isPicked = pickIdx !== -1;
    const allFilled = myPicks.filter(p => p).length === 3;
    const disabled = !isPicked && allFilled;
    const trackEmoji = idea.track === 'automator' ? '🤖' : idea.track === 'visualizer' ? '📊' : '🧮';

    return `
      <div class="idea-card ${isPicked ? 'picked' : ''} ${disabled ? 'disabled' : ''}" onclick="pickIdea(${idea.id})">
        <div class="track-icon track-${idea.track}">${trackEmoji}</div>
        <div class="idea-info">
          <div class="idea-name">${idea.name}</div>
          <div class="idea-author">${idea.author}</div>
        </div>
        <div class="pick-badge ${isPicked ? 'rank-' + (pickIdx + 1) : 'empty'}">
          ${isPicked ? (pickIdx + 1) : '+'}
        </div>
      </div>
    `;
  }).join('');
}

function submitVotes() {
  if (myPicks.filter(p => p).length < 3) return;
  const data = myPicks.slice();
  if (demoMode) {
    allVotes[currentUser.id] = data;
    localStorage.setItem('hack_votes', JSON.stringify(allVotes));
  } else {
    db.ref('votes/' + currentUser.id).set({
      picks: data,
      role: currentUser.role,
      name: currentUser.name,
      ts: Date.now()
    });
    // Realtime DB write structure normalize
    db.ref('votes/' + currentUser.id).set(data);
  }
  showToast('🎉 Votes locked in!');
  fireConfetti();
  setTimeout(() => {
    document.querySelector('[data-panel="leaderboard"]').click();
  }, 1200);
}

// ════════════════════════════════════════
// LEADERBOARD
// ════════════════════════════════════════
function renderLeaderboard() {
  // Tally points
  const totals = {};
  const voteCount = {};
  let voters = 0;
  let totalPts = 0;

  Object.entries(allVotes).forEach(([userId, picks]) => {
    if (!Array.isArray(picks)) return;
    voters++;
    const user = ALL_USERS.find(u => u.id === userId);
    const isJudge = user?.role === 'judge';
    const mult = isJudge ? JUDGE_MULTIPLIER : 1;
    picks.forEach((ideaId, idx) => {
      if (!ideaId) return;
      const pts = (3 - idx) * mult; // 1st=3, 2nd=2, 3rd=1, times mult
      totals[ideaId] = (totals[ideaId] || 0) + pts;
      voteCount[ideaId] = (voteCount[ideaId] || 0) + 1;
      totalPts += pts;
    });
  });

  const ranked = IDEAS
    .map(i => ({
      ...i,
      pts: totals[i.id] || 0,
      votes: voteCount[i.id] || 0
    }))
    .sort((a, b) => b.pts - a.pts || b.votes - a.votes);

  // Stats
  document.getElementById('totalVoters').textContent = voters;
  document.getElementById('totalIdeas').textContent = ranked.filter(r => r.pts > 0).length;
  document.getElementById('totalPoints').textContent = totalPts;

  // Podium (top 3)
  const podium = document.getElementById('podium');
  const top3 = ranked.slice(0, 3);
  if (top3.length >= 3 && top3[0].pts > 0) {
    podium.innerHTML = `
      <div class="podium-spot podium-2">
        <div class="podium-medal">🥈</div>
        <div class="podium-rank">2</div>
        <div class="podium-name">${top3[1].name}</div>
        <div class="podium-pts">${top3[1].pts}</div>
      </div>
      <div class="podium-spot podium-1">
        <div class="podium-medal">🏆</div>
        <div class="podium-rank">1</div>
        <div class="podium-name">${top3[0].name}</div>
        <div class="podium-pts">${top3[0].pts}</div>
      </div>
      <div class="podium-spot podium-3">
        <div class="podium-medal">🥉</div>
        <div class="podium-rank">3</div>
        <div class="podium-name">${top3[2].name}</div>
        <div class="podium-pts">${top3[2].pts}</div>
      </div>
    `;
  } else {
    podium.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-dim);font-size:14px;">🤔 No votes yet. Be the first!</div>`;
  }

  // Rest of leaderboard (4+)
  const rest = document.getElementById('lbRest');
  rest.innerHTML = ranked.slice(3).filter(r => r.pts > 0).map((r, i) => {
    const newRank = i + 4;
    const oldIdx = lastRanking.indexOf(r.id);
    const moved = oldIdx !== -1 && oldIdx > i + 3;
    return `
      <div class="lb-row ${moved ? 'up' : ''}">
        <div class="lb-rank-num">${newRank}</div>
        <div>
          <div class="lb-name">${r.name}</div>
          <div class="lb-author">${r.author}</div>
        </div>
        <div class="lb-votes">${r.votes} 🗳️</div>
        <div class="lb-pts">${r.pts}</div>
      </div>
    `;
  }).join('');

  lastRanking = ranked.map(r => r.id);
}

// ════════════════════════════════════════
// EFFECTS
// ════════════════════════════════════════
function showToast(msg, isError) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (isError ? ' error' : '');
  setTimeout(() => t.className = 'toast' + (isError ? ' error' : ''), 2500);
}

function vibrate(ms) {
  if (navigator.vibrate) navigator.vibrate(ms);
}

function fireConfetti() {
  const colors = ['#ff2e93', '#00f0ff', '#ffd60a', '#39ff14', '#b026ff'];
  for (let i = 0; i < 80; i++) {
    const el = document.createElement('div');
    el.className = 'confetti';
    el.style.left = Math.random() * 100 + 'vw';
    el.style.background = colors[Math.floor(Math.random() * colors.length)];
    el.style.animationDelay = Math.random() * 0.5 + 's';
    el.style.animationDuration = (2 + Math.random() * 2) + 's';
    el.style.transform = `rotate(${Math.random() * 360}deg)`;
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 4000);
  }
  vibrate([50, 30, 50]);
}

// ════════════════════════════════════════
// GO
// ════════════════════════════════════════
init();
</script>
</body>
</html>
